---
import { DESCRIPTION } from "../consts";
import BaseLayout from "./BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ElfsightReviews from "../components/ElfsightReviews.astro";
import ElfsightGallery from "../components/ElfsightGallery.astro";
const {
  title,
  description = DESCRIPTION,
  heroHeading,
  heroSubheading,
  mainHeading,
  mainContent,
  robots,
} = Astro.props;
const mainParagraph = Array.isArray(mainContent)
  ? mainContent.join(" ").trim()
  : String(mainContent ?? "").trim();
---

<BaseLayout title={`${title}`} description={description} robots={robots}>
  <main id="main-content">
    <Hero heroHeading={heroHeading} heroSubheading={heroSubheading} />
    <ElfsightGallery />
    <div class="container py-5">
      <div class="row">
        <div class="col-12 col-lg-8">
          <h2 class="h1">{mainHeading}</h2>
          {mainParagraph && <p class="lead">{mainParagraph}</p>}
        </div>
        <aside class="col-12 col-lg-4 mt-5 mt-lg-0">
          <ElfsightReviews />
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
