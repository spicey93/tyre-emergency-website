---
import { DESCRIPTION } from "../consts";
import BaseLayout from "./BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ElfsightReviews from "../components/ElfsightReviews.astro";
import ElfsightGallery from "../components/ElfsightGallery.astro";
const {
  title,
  description = DESCRIPTION,
  heroHeading,
  heroSubheading,
  mainHeading,
  mainContent,
} = Astro.props;
const mainParagraph = Array.isArray(mainContent)
  ? mainContent.join(" ").trim()
  : String(mainContent ?? "").trim();
---

<BaseLayout title={`${title}`} description={description}>
  <Hero heroHeading={heroHeading} heroSubheading={heroSubheading} />
  <ElfsightGallery />
  <div class="container py-5">
    <div class="row">
      <main class="col-12 col-lg-8">
        <h1>{mainHeading}</h1>
        {mainParagraph && <p class="lead">{mainParagraph}</p>}
      </main>
      <div class="col-12 col-lg-4 mt-5 mt-lg-0">
        <ElfsightReviews />
      </div>
    </div>
  </div>

</BaseLayout>
