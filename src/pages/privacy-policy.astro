---
import BaseLayout from "../layouts/BaseLayout.astro";
import { NAME, EMAIL, PHONE, PHONE_E164, ADDRESS, CITY, COUNTY, POSTCODE } from "../consts";
---

<BaseLayout title="Privacy Policy">
  <main id="main-content" class="container my-5">
    <h1>Privacy Policy</h1>
    <p class="lead">
      This policy explains how {NAME} collects, uses and protects personal data when you use our website, contact us or use our services.
      We process personal data in accordance with the UK GDPR and the Data Protection Act 2018.
    </p>

    <section class="mt-4">
      <h2>1. Who We Are</h2>
      <p>
        Data controller: {NAME}
      </p>
      <p>
        Address: {ADDRESS}, {CITY}, {COUNTY} {POSTCODE}
      </p>
      <p>
        Contact: <a href={`mailto:${EMAIL}`}>{EMAIL}</a> or <a href={`tel:${PHONE_E164}`}>{PHONE}</a>
      </p>
    </section>

    <section class="mt-4">
      <h2>2. Personal Data We Collect</h2>
      <p>Depending on your interaction with us, we may collect:</p>
      <ul>
        <li>Identity and contact details (name, phone number, email address).</li>
        <li>Vehicle and booking details (location, tyre requirements, service history).</li>
        <li>Communication records (messages, calls, enquiry details).</li>
        <li>Technical website data (IP address, browser/device information, cookie preferences).</li>
      </ul>
    </section>

    <section class="mt-4">
      <h2>3. How We Use Your Data</h2>
      <p>We use your personal data to:</p>
      <ul>
        <li>Respond to enquiries and provide quotations.</li>
        <li>Schedule and deliver requested services.</li>
        <li>Manage payments, invoicing and service records.</li>
        <li>Improve website functionality, security and performance.</li>
        <li>Comply with legal and regulatory obligations.</li>
      </ul>
    </section>

    <section class="mt-4">
      <h2>4. Lawful Bases</h2>
      <p>Under UK GDPR, we rely on one or more of the following lawful bases:</p>
      <ul>
        <li><strong>Contract:</strong> where processing is necessary to provide requested services.</li>
        <li><strong>Legitimate interests:</strong> for service administration, fraud prevention and business improvement.</li>
        <li><strong>Legal obligation:</strong> to meet tax, accounting and compliance duties.</li>
        <li><strong>Consent:</strong> for non-essential cookies or marketing where required.</li>
      </ul>
    </section>

    <section class="mt-4">
      <h2>5. Sharing Your Data</h2>
      <p>
        We only share personal data where necessary, including with payment providers, professional advisers, technical providers and legal or regulatory bodies.
        We require third parties to respect data protection obligations.
      </p>
    </section>

    <section class="mt-4">
      <h2>6. International Transfers</h2>
      <p>
        If personal data is transferred outside the UK, we take appropriate safeguards required by law, such as adequacy regulations or approved transfer mechanisms.
      </p>
    </section>

    <section class="mt-4">
      <h2>7. Data Retention</h2>
      <p>
        We keep personal data only for as long as needed for the purposes described above, including legal, tax and accounting retention periods.
      </p>
    </section>

    <section class="mt-4">
      <h2>8. Your Rights</h2>
      <p>Subject to legal limits, you may have rights to:</p>
      <ul>
        <li>Access your personal data.</li>
        <li>Request correction of inaccurate data.</li>
        <li>Request deletion of data in certain circumstances.</li>
        <li>Restrict or object to specific processing.</li>
        <li>Request portability of data you provided to us.</li>
        <li>Withdraw consent where processing is based on consent.</li>
      </ul>
      <p>
        To exercise your rights, contact us at <a href={`mailto:${EMAIL}`}>{EMAIL}</a>.
      </p>
    </section>

    <section class="mt-4">
      <h2>9. Complaints</h2>
      <p>
        If you are unhappy with how we handle your data, please contact us first so we can help. You also have the right to complain to the UK Information Commissioner’s Office (ICO): 
        <a href="https://ico.org.uk" target="_blank" rel="noopener noreferrer">ico.org.uk</a>.
      </p>
    </section>

    <section class="mt-4">
      <h2>10. Cookies</h2>
      <p>
        We use cookies and similar technologies on this website. Please see our <a href="/cookie-policy">Cookie Policy</a> for detailed information and choices.
      </p>
    </section>

    <section class="mt-4">
      <h2>11. Updates to This Policy</h2>
      <p>
        We may update this privacy policy from time to time. The most recent version will be available on this page.
      </p>
      <p class="mb-0"><strong>Last updated:</strong> 30 April 2026</p>
    </section>
  </main>
</BaseLayout>