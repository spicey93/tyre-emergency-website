---
import MainLayout from "../../layouts/MainLayout.astro";
import { AREAS } from "../../consts";

export function getStaticPaths() {
    return AREAS.map((area) => ({
        params: {area: area.link},
        props: { area }
    }))
}

const { area } = Astro.props;
const { title } = area;
---

<MainLayout title={title}>
    <h1>{title}</h1>
</MainLayout>
