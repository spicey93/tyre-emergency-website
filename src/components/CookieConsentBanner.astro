---
const storageKey = "cookieConsentPreferences";
---

<div id="cookie-consent-root" class="cookie-consent d-none" role="region" aria-label="Cookie consent">
  <div class="cookie-consent__card shadow">
    <p class="mb-2 fw-semibold">We use cookies</p>
    <p class="mb-3 small">
      We use strictly necessary cookies to run this website. With your permission, we also use optional analytics and marketing cookies.
      Read our <a href="/cookie-policy">Cookie Policy</a>.
    </p>

    <div id="cookie-consent-manage" class="cookie-consent__manage d-none mb-3">
      <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="cookie-essential" checked disabled />
        <label class="form-check-label" for="cookie-essential">Strictly necessary (always on)</label>
      </div>
      <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="cookie-analytics" />
        <label class="form-check-label" for="cookie-analytics">Analytics cookies</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" id="cookie-marketing" />
        <label class="form-check-label" for="cookie-marketing">Marketing cookies</label>
      </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
      <button id="cookie-accept-all" class="btn btn-sm btn-success" type="button">Accept all</button>
      <button id="cookie-reject" class="btn btn-sm btn-outline-light" type="button">Reject non-essential</button>
      <button id="cookie-manage-toggle" class="btn btn-sm btn-outline-light" type="button">Manage preferences</button>
      <button id="cookie-save-prefs" class="btn btn-sm btn-light d-none" type="button">Save preferences</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ storageKey }}>
  (() => {
    const root = document.getElementById("cookie-consent-root");
    if (!root) return;

    const managePanel = document.getElementById("cookie-consent-manage");
    const manageToggle = document.getElementById("cookie-manage-toggle");
    const savePrefs = document.getElementById("cookie-save-prefs");
    const acceptAll = document.getElementById("cookie-accept-all");
    const reject = document.getElementById("cookie-reject");
    const analyticsInput = document.getElementById("cookie-analytics");
    const marketingInput = document.getElementById("cookie-marketing");

    const defaultConsent = {
      essential: true,
      analytics: false,
      marketing: false,
      updatedAt: "",
    };

    const writeConsent = (consent) => {
      const nextConsent = {
        ...defaultConsent,
        ...consent,
        essential: true,
        updatedAt: new Date().toISOString(),
      };
      localStorage.setItem(storageKey, JSON.stringify(nextConsent));
      window.__cookieConsent = nextConsent;
      window.dispatchEvent(new CustomEvent("cookie-consent-updated", { detail: nextConsent }));
      root.classList.add("d-none");
    };

    const readConsent = () => {
      const raw = localStorage.getItem(storageKey);
      if (!raw) return null;
      try {
        const parsed = JSON.parse(raw);
        return {
          ...defaultConsent,
          ...parsed,
          essential: true,
        };
      } catch (error) {
        localStorage.removeItem(storageKey);
        return null;
      }
    };

    const existingConsent = readConsent();
    if (existingConsent) {
      window.__cookieConsent = existingConsent;
      return;
    }

    root.classList.remove("d-none");

    const setManageOpen = (isOpen) => {
      managePanel.classList.toggle("d-none", !isOpen);
      savePrefs.classList.toggle("d-none", !isOpen);
      manageToggle.textContent = isOpen ? "Hide preferences" : "Manage preferences";
    };

    const applyInputDefaults = () => {
      analyticsInput.checked = false;
      marketingInput.checked = false;
    };

    applyInputDefaults();
    setManageOpen(false);

    acceptAll.addEventListener("click", () => {
      writeConsent({ essential: true, analytics: true, marketing: true });
    });

    reject.addEventListener("click", () => {
      writeConsent({ essential: true, analytics: false, marketing: false });
    });

    manageToggle.addEventListener("click", () => {
      const isHidden = managePanel.classList.contains("d-none");
      setManageOpen(isHidden);
    });

    savePrefs.addEventListener("click", () => {
      writeConsent({
        essential: true,
        analytics: Boolean(analyticsInput.checked),
        marketing: Boolean(marketingInput.checked),
      });
    });
  })();
</script>

<style>
  .cookie-consent {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 1055;
  }

  .cookie-consent__card {
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    background-color: #212529;
    color: #f8f9fa;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.5rem;
    padding: 1rem;
  }

  .cookie-consent__card a {
    color: #9ec5fe;
  }

  .cookie-consent__manage {
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.5rem;
    padding: 0.75rem;
  }
</style>
