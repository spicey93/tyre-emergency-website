---
import {
  NAME,
  DESCRIPTION,
  PHONE,
  EMAIL,
  VAT_NO,
  COMPANY_NO,
  YEAR,
  ADDRESS,
  CITY,
  COUNTY,
  POSTCODE,
  DESIGNER_CREDIT,
} from "../consts";
import SocialLinks from "./SocialLinks.astro";
import CTA from "./CTA.astro";
---

<CTA />
<footer class="bg-dark text-light">
  <div class="container pt-4 pb-3">
    <div class="row">
      <div class="col-md-4 mb-4 mb-md-0">
        <h5 class="mb-3">{NAME}</h5>
        {DESCRIPTION && <p class="small mb-3">{DESCRIPTION}</p>}
        <SocialLinks />
      </div>

      <div class="col-md-4 mb-4 mb-md-0">
        <h6 class="mb-3">Quick Links</h6>
        <ul class="list-unstyled small">
          <li>
            <a href="/about" class="link-light text-decoration-none">About</a>
          </li>
          <li>
            <a href="/contact" class="link-light text-decoration-none"
              >Contact</a
            >
          </li>
          <li>
            <a href="/terms-and-conditions" class="link-light text-decoration-none"
              >Terms and Conditions</a
            >
          </li>
          <li>
            <a href="/privacy-policy" class="link-light text-decoration-none"
              >Privacy Policy</a
            >
          </li>
          <li>
            <a href="/cookie-policy" class="link-light text-decoration-none"
              >Cookie Policy</a
            >
          </li>
        </ul>
      </div>

      <div class="col-md-4">
        <h6 class="mb-3">Contact</h6>
        <p class="small mb-0">{ADDRESS}, {CITY}, {COUNTY} {POSTCODE}</p>
        <div class="small">
          <a href={`tel:${PHONE}`} class="link-light text-decoration-none">
            {PHONE}
          </a><br />
          <a href={`mailto:${EMAIL}`} class="link-light text-decoration-none">
            {EMAIL}
          </a>
        </div>
      </div>
    </div>

    <hr class="border-light opacity-10" />

    <div
      class="d-flex flex-column flex-md-row justify-content-between small align-items-center"
    >
      <div>© {YEAR} {NAME}. All rights reserved.</div>

      <div class="small mt-2 mt-md-0">
        VAT: {VAT_NO} • Company No: {COMPANY_NO}
      </div>

      {
        DESIGNER_CREDIT && (
          <div class="mt-2 mt-md-0">
            <a
              href={DESIGNER_CREDIT.url}
              target="_blank"
              rel="noopener noreferrer"
              class="link-light text-decoration-none d-inline-flex align-items-center"
              aria-label={DESIGNER_CREDIT.ariaLabel}
              title={DESIGNER_CREDIT.title}
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                class="me-2"
                aria-hidden="true"
                focusable="false"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <circle cx="12" cy="12" r="7" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <span class="small">{DESIGNER_CREDIT.label}</span>
            </a>
          </div>
        )
      }
    </div>
  </div>
</footer>
