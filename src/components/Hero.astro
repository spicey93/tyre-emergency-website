---
import TyreBrands from "./TyreBrands.astro";
import { SERVICES, PHONE, AREAS, GOOGLE_REVIEWS } from "../consts";
const {
  heroHeading = "Hero Heading",
  heroSubheading = "This is the Hero Subheading section. You can write an engaging sentence here to get a conversion.",
  bgImg = "/src/assets/images/tyre-emergency-ltd.jpeg",
} = Astro.props;
---

<div
  id="hero"
  class="d-flex align-items-center text-lg-start"
  style={`background-image: url('${bgImg}')`}
>
  <div class="container">
    <div class="row">
      <div
        class="col-lg-6 my-5 text-light text-center text-lg-start d-flex flex-column justify-content-center"
      >
        <p class="h1 fw-bold display-5">{heroHeading}</p>
        <p class="lead">{heroSubheading}</p>
        <div>
          <a href={`tel:${PHONE}`} class="btn btn-secondary fw-bold btn-lg my-3">Call us on <i class="bi bi-telephone-fill me-2"></i>{PHONE}</a>
        </div>
        <div class="my-3">
          <span class="border px-3 py-2 rounded">
            Rated <i class="bi bi-star-fill text-warning"></i><i class="bi bi-star-fill text-warning"></i><i class="bi bi-star-fill text-warning"></i><i class="bi bi-star-fill text-warning"></i><i class="bi bi-star-fill text-warning"></i> on Google from {GOOGLE_REVIEWS} reviews
          </span>
        </div>

      </div>
      <div class="col mb-5 offset-lg-1 mt-lg-5">
        <div class="bg-light p-5 rounded m-3">
          <p class="h3 mb-4 text-center">Get a Quote</p>
          <form
            class="row g-3"
            name="contact"
            method="POST"
            action="/thank-you"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="d-none">
              <label>
                Do not fill this out if you are human:
                <input name="bot-field" />
              </label>
            </p>
            <div class="col-12 col-lg-6">
              <label class="visually-hidden" for="heroFullName">Full Name</label>
              <input
                type="text"
                class="form-control"
                placeholder="Full Name"
                id="heroFullName"
                name="fullName"
                autocomplete="name"
                required
              />
            </div>
            <div class="col-12 col-lg-6">
              <label class="visually-hidden" for="heroPhone">Phone Number</label>
              <input
                type="tel"
                class="form-control"
                placeholder="Phone Number"
                id="heroPhone"
                name="phone"
                autocomplete="tel"
                inputmode="tel"
                required
              />
            </div>
            <div class="col-12">
              <label class="visually-hidden" for="heroServiceType">Service Needed</label>
              <select name="serviceType" id="heroServiceType" class="form-select" required>
                <option value="">What service do you require?</option>
                {
                  SERVICES.map((serv) => (
                    <option value={serv.title}>{serv.title}</option>
                  ))
                }
              </select>
            </div>
            <div class="col-12">
              <label class="visually-hidden" for="heroArea">Area</label>
              <select name="area" id="heroArea" class="form-select" required>
                <option value="">What area are you in?</option>
                {
                  AREAS.map((area) => (
                    <option value={area.name}>{area.name}</option>
                  ))
                }
              </select>
            </div>
            <div class="col-12">
              <label class="visually-hidden" for="heroMessage">Message</label>
              <textarea name="message" id="heroMessage" class="form-control" rows="4" placeholder="Leave us a message"
              ></textarea>
            </div>
            <div class="col-12 d-grid">
              <button class="btn btn-primary text-light fw-bold"
                ><i class="bi bi-send-fill me-2"></i>Request Quote</button
              >
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<TyreBrands />
<style>
  #hero {
    min-height: 70vh;
    background-size: cover;
    background-position: center;
    position: relative;
  }

  #hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.85);
    z-index: 1;
  }

  #hero .container {
    position: relative;
    z-index: 2;
  }
</style>
