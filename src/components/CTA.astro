---
import { PHONE } from "../consts.ts";
---

<div class="bg-dark border-bottom border-primary text-light">
    <div class="container">
        <div class="row align-items-center justify-content-center py-4 text-light">
            <div class="col-12 col-lg-auto text-center text-lg-start mb-3 mb-lg-0">
                <i class="bi bi-telephone-fill me-2 text-primary"></i> <span>Call us on <a href={`tel:${PHONE}`} class="link-light text-decoration-none fw-bold me-3">{PHONE}</a>
                </span>
                <span class="separator d-none d-lg-inline mx-3">|</span>
            </div>
            <div class="col-12 col-lg-auto text-center">
                <a href="/contact" class="btn btn-primary text-light fw-bold"><i class="bi bi-send-fill me-2"></i>Get Quote</a>
            </div>
        </div>
    </div>
</div>

