---
import { Image } from "astro:assets";
import bridgestone from "../assets/tyre-brands/bridgestone.jpg";
import continental from "../assets/tyre-brands/continental.jpg";
import dunlop from "../assets/tyre-brands/dunlop.jpg";
import firestone from "../assets/tyre-brands/firestone.jpg";
import goodyear from "../assets/tyre-brands/goodyear.jpg";
import hankook from "../assets/tyre-brands/hankook.jpg";
import michelin from "../assets/tyre-brands/michelin.jpg";
import pirelli from "../assets/tyre-brands/pirelli.jpg";

const brands = [
  { name: "Bridgestone", src: bridgestone },
  { name: "Continental", src: continental },
  { name: "Dunlop", src: dunlop },
  { name: "Firestone", src: firestone },
  { name: "Goodyear", src: goodyear },
  { name: "Hankook", src: hankook },
  { name: "Michelin", src: michelin },
  { name: "Pirelli", src: pirelli },
];
---

<section class="py-4 bg-light border-bottom">
  <div class="carousel-container">
    <div class="carousel-track">
      {
        [...brands, ...brands].map((brand) => (
          <div class="brand-item">
            <Image src={brand.src} alt={`${brand.name} tyres`} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .carousel-container {
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    gap: 3rem;
    animation: scroll 30s linear infinite;
    width: fit-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .brand-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 150px;
    height: 60px;
  }

  .brand-item img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.6);
    transition: filter 0.3s ease;
  }

  .brand-item:hover img {
    filter: grayscale(0%) opacity(1);
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .carousel-track {
      gap: 2rem;
      animation-duration: 20s;
    }

    .brand-item {
      width: 120px;
      height: 50px;
    }
  }
</style>
